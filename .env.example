# ============================================================
# AutoEscuela Bot — Variables de entorno
# Copia este archivo como .env y rellena los valores
# .env está en .gitignore — nunca subas credenciales reales
# ============================================================

# ── Twilio WhatsApp ──────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_SANDBOX_NUM=whatsapp:+14155238886
# Cuando tengas número propio:
# TWILIO_SANDBOX_NUM=whatsapp:+34XXXXXXXXX

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# SERVICE_KEY (secret) — solo para el bot (backend)
# Para el CRM (frontend) usa la ANON KEY desde la configuración de la app

# ── Autoescuela ───────────────────────────────────────────────
SCHOOL_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# UUID de la fila en la tabla schools de Supabase
# Obtenerlo tras ejecutar el schema y crear la primera escuela

# ── Notificaciones ───────────────────────────────────────────
NOTIFY_ADMIN=+34600000000
# Teléfono que recibe avisos de admin (con prefijo país)

# ── Servidor ─────────────────────────────────────────────────
PORT=3002
# Railway asigna PORT automáticamente — no hace falta tocarlo en producción
